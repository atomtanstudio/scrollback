# FeedSilo Configuration
# ─────────────────────────────────────────────────
# Option 1: Run `npm run dev` and use the onboarding wizard (recommended)
# Option 2: Copy this file to .env.local and fill in values manually
# Environment variables override feedsilo.config.json values

# Database
# PostgreSQL/Supabase example:
DATABASE_URL=postgresql://user:password@localhost:5432/feedsilo
DATABASE_TYPE=postgresql  # postgresql | supabase | sqlite
# SQLite example:
# DATABASE_URL=file:./feedsilo.db
# DATABASE_TYPE=sqlite

# AI provider (optional: embeddings, summaries, tags, translations, image descriptions)
# Choose one provider through onboarding/settings, or set one manually here.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Extension auth (legacy/global token; per-user tokens are available in Settings)
CAPTURE_SECRET=

# Auth.js (NextAuth v5)
AUTH_SECRET=your-secret-here  # Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Search tuning
SEARCH_KEYWORD_WEIGHT=0.4
SEARCH_VECTOR_WEIGHT=0.6

# Media storage (Cloudflare R2, optional)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=feedsilo-media

# Local media storage (optional alternative to R2)
# LOCAL_MEDIA_PATH=./media

# X API v2 integration (optional)
# Requires an X API plan (pay-as-you-go available) from developer.x.com
# XAPI_BEARER_TOKEN=            # App-only Bearer Token for tweet lookup fallback
# XAPI_CLIENT_ID=               # OAuth 2.0 Client ID (for user-context flows)
# XAPI_CLIENT_SECRET=           # OAuth 2.0 Client Secret
# XAPI_ENCRYPTION_KEY=          # Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Demo/read-only user (optional)
# DEMO_EMAIL=
# DEMO_PASSWORD=

# Waitlist notification logging (optional)
# WAITLIST_NOTIFY_EMAIL=
